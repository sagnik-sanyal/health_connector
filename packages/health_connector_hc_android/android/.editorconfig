# EditorConfig for Kotlin/Android - Ktlint Configuration
# https://editorconfig.org/
# https://pinterest.github.io/ktlint/latest/rules/configuration-ktlint/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 100

# Ktlint code style - Android Studio conventions
ktlint_code_style = android_studio

# Disable package-name rule - Flutter plugins often use snake_case vs Kotlin's camelCase
ktlint_standard_package-name = disabled

# Trailing comma - enabled for better git diffs (Kotlin 1.4+)
ktlint_standard_trailing-comma-on-call-site = enabled
ktlint_standard_trailing-comma-on-declaration-site = enabled
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

# Import Layout - Adhering to Google Android Style Guide
# 1. Android/AndroidX
# 2. Third-party (*)
# 3. Java
# 4. Kotlin
# 5. Aliases (^)
# The '|' character forces a blank line between groups
ij_kotlin_imports_layout = android.,androidx.,|,*,|,java.,javax.,|,kotlin.,|,^

# Enable no-unused-imports rule
ktlint_standard_no-unused-imports = enabled

# Wildcard imports - Disable wildcards by setting threshold very high
ij_kotlin_name_count_to_use_star_import = 999
ij_kotlin_name_count_to_use_star_import_for_members = 999
ij_kotlin_packages_to_use_import_on_demand = unset
ktlint_standard_no-wildcard-imports = enabled

# Filename matching - Enabled for normal files to ensure class names match filenames
ktlint_standard_filename = enabled

# Spacing and Code Structure
ktlint_standard_comment-spacing = enabled
ktlint_standard_no-blank-line-before-rbrace = enabled

# Indentation settings for proper arrow and continuation line formatting
# Prevents double-indentation of continuation lines (e.g., when arrow expressions)
ij_kotlin_continuation_indent_size = 4
# Prevents arrow from starting on new line with extra indent
ij_kotlin_indent_before_arrow_on_new_line = false

# Disable binary-expression-wrapping rule (often conflicts with IntelliJ formatter)
# TODO: Revisit in future ktlint versions - may have improved compatibility
ktlint_standard_binary-expression-wrapping = disabled

# Braces on control structures (Kotlin 1.5+ recommended, ktlint 0.49+)
# Enforces explicit braces on if/when for consistency and safety
ktlint_standard_braces-on-if-statements = enabled
ktlint_standard_braces-on-when-statements = enabled

# Function naming - allow @Composable and other annotation-based exceptions
ij_kotlin_function_naming_ignore_when_annotated_with = Composable

# Pigeon-generated files - completely disable ktlint for auto-generated code
# These files are auto-generated by Pigeon and should not be modified manually
[**/*.g.kt]
ktlint = disabled
generated_code = true

[*.xml]
indent_size = 4

[*.{gradle,gradle.kts}]
indent_size = 4
