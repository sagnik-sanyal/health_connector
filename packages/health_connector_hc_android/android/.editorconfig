# EditorConfig for Kotlin/Android - Ktlint Configuration
# https://editorconfig.org/
# https://pinterest.github.io/ktlint/latest/rules/configuration-ktlint/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 100

# Ktlint code style - Android Studio conventions
ktlint_code_style = android_studio

# Disable package-name rule - Flutter plugins use underscores by convention
ktlint_standard_package-name = disabled

# Trailing comma - enabled for better git diffs (Kotlin 1.4+)
ktlint_standard_trailing-comma-on-call-site = enabled
ktlint_standard_trailing-comma-on-declaration-site = enabled
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

# Import ordering for Android projects
ij_kotlin_imports_layout = *,android.,androidx.,com.,org.,java.,kotlin.,^

# Enable no-unused-imports rule (disabled by default in Ktlint 1.7.0+)
ktlint_standard_no-unused-imports = enabled

# Wildcard imports - Android typically allows some wildcard imports
ij_kotlin_name_count_to_use_star_import = 5
ij_kotlin_name_count_to_use_star_import_for_members = 3

# Disable some rules that may conflict with generated code
ktlint_standard_filename = disabled

# Disable binary-expression-wrapping rule (known issues in Ktlint 1.7.0)
ktlint_standard_binary-expression-wrapping = disabled

# Function naming - allow @Composable annotations
ktlint_function_naming_ignore_when_annotated_with = Composable

# Pigeon-generated files - completely disable ktlint for auto-generated code
# These files are auto-generated by Pigeon and should not be modified manually
[**/*.g.kt]
ktlint = disabled
generated_code = true

[*.xml]
indent_size = 4

[*.{gradle,gradle.kts}]
indent_size = 4
